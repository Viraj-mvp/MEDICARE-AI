# MongoDB Local (Compass)
MONGODB_URI=mongodb://localhost:27017/medicare_ai

# Groq API (Tier 1 Prediction)
GROQ_API_KEY=your_groq_api_key

# Gemini API (Tier 2 Prediction)
GEMINI_API_KEY=your_gemini_api_key

# JWT Secret (REQUIRED: Must be at least 64 characters long)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_must_be_64_chars_long_generate_one_now

# Next Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key

# News API
NEWS_API_KEY=your_news_api_key

# Emergency SOS
EMERGENCY_ADMIN_EMAIL=your_email@example.com

# External APIs
YOUTUBE_API_KEY=your_youtube_api_key
OPENCAGE_API_KEY=your_opencage_api_key
FAST2SMS_API_KEY=your_fast2sms_api_key
